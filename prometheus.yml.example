# Example Prometheus configuration for scraping KSP Data Export metrics
#
# To use this configuration:
# 1. Copy this file to your Prometheus installation directory
# 2. Rename it to prometheus.yml (or merge with your existing config)
# 3. Restart Prometheus
# 4. Start KSP with the Data Export mod and ensure prometheusEnabled=True in logged.vals
# 5. Visit http://localhost:9090 to access Prometheus UI

global:
  scrape_interval: 1s      # Scrape targets every second (matches default WaitTime in KSP mod)
  evaluation_interval: 1s   # Evaluate rules every second

# Scrape configurations
scrape_configs:
  # KSP Data Export metrics
  - job_name: 'ksp'

    # Scrape interval for this job (override global if needed)
    scrape_interval: 1s

    # Timeout for scraping
    scrape_timeout: 1s

    # Static configuration for local KSP instance
    static_configs:
      - targets: ['localhost:9101']
        labels:
          instance: 'ksp-local'
          game: 'kerbal-space-program'

    # Optional: Only scrape when KSP is running
    # If the target is down, Prometheus will mark it as unavailable
    honor_labels: true

# Optional: Alerting rules (create alerts.yml separately)
# rule_files:
#   - "alerts.yml"

# Optional: Configure alertmanager
# alerting:
#   alertmanagers:
#     - static_configs:
#         - targets: ['localhost:9093']
