      "id": 100,
      "title": "📊 实时状态",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GREPTIMEDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "orange", "value": 500 },
            { "color": "red", "value": 1000 }
          ]},
          "unit": "velocityms",
          "decimals": 1
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "orientation": "auto" },
      "targets": [{ "expr": "ksp_surface_speed_m_per_s{vessel=~\"$vessel\"}", "legendFormat": "", "refId": "A" }],
      "title": "🚀 表面速度",
      "description": "飞行器相对地面的速度",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GREPTIMEDB}" },
